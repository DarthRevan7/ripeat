  dialogueLines:
  - line: "Questa citt\xE0 non dorme mai, eh? Ma dimmi, sei pi\xF9 tipo da fare rumore
      o da muoverti nell'ombra?"
    speaker: Barista
  responses:
  - responseText: Osservo. Il silenzio paga.
    dialogueObject: {fileID: 11400000, guid: 64f7edafb538db2469eeb97329f111fc, type: 2}
    pointValue: 0
  - responseText: Voglio il rumore.
    dialogueObject: {fileID: 11400000, guid: 64f7edafb538db2469eeb97329f111fc, type: 2}
    pointValue: 0
  - responseText: Mi nascondo.
    dialogueObject: {fileID: 11400000, guid: 64f7edafb538db2469eeb97329f111fc, type: 2}
    pointValue: 0
  isFinalDialogue: 0
