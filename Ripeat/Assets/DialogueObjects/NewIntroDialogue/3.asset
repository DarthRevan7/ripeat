  dialogueLines:
  - line: "Ecco a te il drink. Allora, sei uno di quelli che annega i dispiaceri,
      festeggia una vittoria, o semplicemente scappa dalla noia l\xE0 fuori?"
    speaker: Barista
  responses:
  - responseText: Voglio solo pensare.
    dialogueObject: {fileID: 11400000, guid: 04d3dda8e04cd604b857d0e389fe2c76, type: 2}
    pointValue: 0
  - responseText: Sono pronto a tutto.
    dialogueObject: {fileID: 11400000, guid: 04d3dda8e04cd604b857d0e389fe2c76, type: 2}
    pointValue: 0
  - responseText: Cerco l'ispirazione.
    dialogueObject: {fileID: 11400000, guid: 04d3dda8e04cd604b857d0e389fe2c76, type: 2}
    pointValue: 0
